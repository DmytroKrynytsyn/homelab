receivers:
  hostmetrics:
    collection_interval: 30s
    scrapers:
      cpu:
      memory:
      disk:
      filesystem:
      network:
      processes:

  filelog/system:
    include:
      - /var/log/syslog
    start_at: beginning

processors:
  resource/infra:
    attributes:
      - key: layer
        value: infra
        action: insert
{% if otel_node_name is defined %}
      - key: node_name
        value: "{{ otel_node_name }}"
        action: insert
{% endif %}

  batch:
    timeout: 10s

exporters:
  prometheusremotewrite:
    endpoint: "{{ victoria_metrics_endpoint | default('http://victoriametrics.local/api/v1/write') }}"
{% if victoria_metrics_host is defined %}
    headers:
      Host: "{{ victoria_metrics_host }}"
{% endif %}
    tls:
      insecure: true

  otlphttp/victorialogs:
    endpoint: "{{ victoria_logs_endpoint | default('http://victorialogs.local/insert/opentelemetry') }}"
{% if victoria_logs_host is defined %}
    headers:
      Host: "{{ victoria_logs_host }}"
{% endif %}
    tls:
      insecure: true

service:
  pipelines:
    metrics:
      receivers: [hostmetrics]
      processors: [resource/infra, batch]
      exporters: [prometheusremotewrite]

    logs:
      receivers: [filelog/system]
      processors: [resource/infra, batch]
      exporters: [otlphttp/victorialogs]