receivers:
  hostmetrics:
    collection_interval: 30s
    scrapers:
      cpu:
      memory:
      disk:
      filesystem:
      network:
      processes:

  filelog/system:
    include:
      - /var/log/syslog
    start_at: beginning

{% if ollama_enabled %}
  prometheus/ollama:
    config:
      scrape_configs:
        - job_name: ollama
          scrape_interval: 30s
          static_configs:
            - targets: ["localhost:{{ ollama_port }}"]
{% endif %}

processors:
  resource/infra:
    attributes:
      - key: layer
        value: infra
        action: insert

{% if ollama_enabled %}
  resource/llm:
    attributes:
      - key: layer
        value: llm
        action: insert
{% endif %}

  batch:
    timeout: 10s

exporters:
  prometheusremotewrite:
    endpoint: http://victoriametrics.local/api/v1/write
    tls:
      insecure: true

  otlphttp/victorialogs:
    endpoint: http://victorialogs.local/insert/opentelemetry
    tls:
      insecure: true

service:
  pipelines:
    metrics:
      receivers: [hostmetrics]
      processors: [resource/infra, batch]
      exporters: [prometheusremotewrite]

    logs:
      receivers: [filelog/system]
      processors: [resource/infra, batch]
      exporters: [otlphttp/victorialogs]

{% if ollama_enabled %}
    metrics/ollama:
      receivers: [prometheus/ollama]
      processors: [resource/llm, batch]
      exporters: [prometheusremotewrite]
{% endif %}