receivers:
  hostmetrics:
    collection_interval: 30s
    scrapers:
      cpu:
      memory:
      disk:
      filesystem:
      network:
      processes:

  filelog/system:
    include:
      - /var/log/syslog
    start_at: beginning

processors:
  resourcedetection:
    detectors: [env, system]
    system:
      hostname_sources: [os]

  resource/infra:
    attributes:
      - key: layer
        value: infra
        action: insert

  batch:
    timeout: 10s

exporters:
  prometheusremotewrite:
    endpoint: http://victoriametrics.local/api/v1/write
    resource_to_telemetry_conversion:
      enabled: true
    tls:
      insecure: true

  otlphttp/victorialogs:
    endpoint: http://victorialogs.local/insert/opentelemetry
    tls:
      insecure: true

service:
  pipelines:
    metrics:
      receivers: [hostmetrics]
      processors: [resourcedetection, resource/infra, batch]
      exporters: [prometheusremotewrite]

    logs:
      receivers: [filelog/system]
      processors: [resourcedetection, resource/infra, batch]
      exporters: [otlphttp/victorialogs]