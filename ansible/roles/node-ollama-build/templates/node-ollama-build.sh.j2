#!/bin/bash
set -euo pipefail

BASE_DIR="{{ ollama_build_base_dir }}"
BUILD_DIR=$(mktemp -d)
TIMESTAMP=$(date +%Y%m%d%H%M%S)
DEST_DIR="$BASE_DIR/$TIMESTAMP"

cleanup() {
  echo "[cleanup] removing cloned repo and build tree $BUILD_DIR"
  rm -rf "$BUILD_DIR"
}
trap cleanup EXIT

echo "=== node-ollama-build $(date --iso-8601=seconds) ==="

echo "[clone] cloning llama.cpp"
git clone --depth 1 {{ ollama_build_repo_url }} "$BUILD_DIR"

echo "[build] configuring"
cmake -B "$BUILD_DIR/build" -S "$BUILD_DIR" \
  -DBUILD_SHARED_LIBS=OFF \
  -DCMAKE_BUILD_TYPE=Release \
  -DCMAKE_C_FLAGS="-march=native" \
  -DCMAKE_CXX_FLAGS="-march=native" \
  -DCMAKE_EXE_LINKER_FLAGS="-static" \
  -DGGML_OPENMP=OFF

echo "[build] compiling llama-server"
cmake --build "$BUILD_DIR/build" --config Release -j"$(nproc)" --target llama-server

echo "[install] staging stripped binary in $DEST_DIR"
mkdir -p "$DEST_DIR"
strip "$BUILD_DIR/build/bin/llama-server"
cp "$BUILD_DIR/build/bin/llama-server" "$DEST_DIR/"

echo "[latest] pointing latest -> $TIMESTAMP"
ln -sfn "$DEST_DIR" "$BASE_DIR/latest"

echo "[retain] keeping last {{ ollama_build_retain_count }} builds"
cd "$BASE_DIR"
ls -1d [0-9]* 2>/dev/null | sort -r | tail -n +$(({{ ollama_build_retain_count }} + 1)) | xargs -r rm -rf

echo "[done] build complete: $DEST_DIR"
