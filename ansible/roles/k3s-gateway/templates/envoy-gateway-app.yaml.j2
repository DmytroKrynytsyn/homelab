apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: envoy-gateway
  namespace: argocd
spec:
  project: default
  source:
    repoURL: docker.io/envoyproxy
    chart: gateway-helm
    targetRevision: {{ envoy_gateway_version }}
    helm:
      valuesObject:
        config:
          envoyGateway:
            logging:
              level:
                default: info
        deployment:
          pod:
            nodeSelector:
              purpose: kcontrol
  destination:
    server: https://kubernetes.default.svc
    namespace: envoy-gateway-system
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true