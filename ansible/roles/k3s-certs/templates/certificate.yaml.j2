apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: homelab-tls
  namespace: envoy-gateway-system
spec:
  secretName: homelab-tls
  issuerRef:
    name: selfsigned
    kind: ClusterIssuer
  duration: {{ homelab_tls_duration }}
  renewBefore: {{ homelab_tls_renew_before }}
  dnsNames:
{% for name in homelab_tls_dns_names %}
    - {{ name | quote }}
{% endfor %}
